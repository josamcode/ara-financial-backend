# Development environment only. Copy to .env for local development.
# Use .env.test.example for backend tests.

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ara_financial_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-local-development-only
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
INVITATION_EXPIRY=7d
PASSWORD_RESET_EXPIRY=1h
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m
EXPOSE_EMAIL_ACTION_TOKENS=false

# App URLs
APP_BASE_URL=http://localhost:5000

# Bcrypt
BCRYPT_ROUNDS=12

# Login Throttling
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# HTTP / CORS
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3000

# Reporting
REPORT_CACHE_TTL_SECONDS=60

# Logging
LOG_LEVEL=debug

# SMTP (optional - required for invoice email sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary (optional unless tenant logo upload is used)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
