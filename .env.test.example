# Test environment only. Do not use production or Atlas MongoDB URIs here.
NODE_ENV=test
PORT=5001

# MongoDB database name must contain "test" or "ci".
MONGODB_URI=mongodb://localhost:27017/ara_financial_test

# Redis test DB keeps test state separate from local development.
REDIS_URL=redis://localhost:6379/1

JWT_SECRET=test-only-jwt-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
INVITATION_EXPIRY=7d
PASSWORD_RESET_EXPIRY=1h
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m
EXPOSE_EMAIL_ACTION_TOKENS=false

BCRYPT_ROUNDS=4
LOGIN_RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
TRUST_PROXY=false
CORS_ORIGINS=
REPORT_CACHE_TTL_SECONDS=1
LOG_LEVEL=silent

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
